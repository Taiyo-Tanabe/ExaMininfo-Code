# このファイルをコピーして .env を作り、値を書き換えてください
# cp .env.example .env

# ローカル開発用（個別指定）
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=examininfo_db

# 本番（Render等）はこちら1本で指定
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# python -c "import secrets; print(secrets.token_hex(32))" で生成
SECRET_KEY=change_this_to_a_long_random_string

ALLOWED_ORIGINS=http://localhost:5173
